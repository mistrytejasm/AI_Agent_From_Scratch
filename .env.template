# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_DEFAULT_MODEL=llama3-8b-8192

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=chatbot_db

# Tavily API Configuration (Get a free key from https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Local LLM Configuration (Optional, fallback to Groq if disabled or offline)
USE_LOCAL_LLM=False
LOCAL_LLM_BASE_URL=http://localhost/v1
LOCAL_LLM_API_KEY=my-local-secret-key-2026
LOCAL_LLM_MODEL=qwen3.5-4b

# Embedding Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
